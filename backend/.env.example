# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.

MONGO_URI=mongodb+srv://<user>:<password>@<cluster-url>/<db-name>?appName=Cluster0
PORT=5000

UPSTASH_REDIS_REST_URL=https://<your-upstash-instance>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-upstash-token>

# Generate a strong random value, e.g.: openssl rand -hex 32
JWT_SECRET=<your-jwt-secret>

# Comma-separated list of allowed origins for CORS. Leave unset for local dev.
# ALLOWED_ORIGINS=https://your-production-domain.com